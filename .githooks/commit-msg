#!/bin/sh
# Strips AI attribution trailers from every commit message.
# Enable once per clone with:  git config core.hooksPath .githooks
tmp="$1.tmp"
grep -v -i -e '^Co-Authored-By: Claude' \
           -e '^Claude-Session:' \
           -e 'Generated with \[Claude Code\]' \
           -e '🤖 Generated with' "$1" > "$tmp" || true
mv "$tmp" "$1"
